{
  "name": "@poncho-ai/harness",
  "version": "0.38.0",
  "description": "Agent execution runtime - conversation loop, tool dispatch, streaming",
  "repository": {
    "type": "git",
    "url": "https://github.com/cesr/poncho-ai.git",
    "directory": "packages/harness"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/embed-docs.js && tsup src/index.ts --format esm --dts",
    "dev": "node scripts/embed-docs.js && tsup src/index.ts --format esm --dts --watch",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.44",
    "@ai-sdk/openai": "^3.0.29",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@poncho-ai/sdk": "workspace:*",
    "ai": "^6.0.86",
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.2.0",
    "jiti": "^2.6.1",
    "jose": "^6.2.2",
    "just-bash": "^2.14.0",
    "mustache": "^4.2.0",
    "yaml": "^2.4.0",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "esbuild": ">=0.17.0",
    "isolated-vm": ">=5.0.0",
    "postgres": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "isolated-vm": {
      "optional": true
    },
    "postgres": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/mustache": "^4.2.6",
    "esbuild": "^0.28.0",
    "isolated-vm": "^6.1.2",
    "tsup": "^8.0.0",
    "vitest": "^1.4.0"
  },
  "keywords": [
    "ai",
    "agent",
    "harness",
    "runtime"
  ],
  "license": "MIT"
}
